{
    // 本文件主要定义了通用 UI 的行为和显示内容
    // 可参考文档和示例添加更多您需要的功能
    // 文档：https://maafw.xyz/docs/3.3-ProjectInterfaceV2
    // 示例：https://github.com/MaaXYZ/MaaFramework/blob/main/sample/interface.json
    "interface_version": 2,
    "name": "Maapvz_早安",
    "license": "MIT",
    "welcome": "看到这段话的都是🐖",
    "icon": "logo.ico",
    // 填写项目地址和版本号可实现自动更新功能
    "github": "https://github.com/Xiao-yu-ze/mpz",
    "version": "0.4.5",
    // Mirror酱为第三方分发服务，新项目默认关闭
    // 若有需要请联系 Mirror酱 开通，直接自行开启是无法使用的
    // "mirrorchyan_rid": "MaaXXX",
    // "mirrorchyan_multiplatform": true,
    "controller": [
        {
            "name": "安卓端",
            "type": "Adb",
            "display_short_side": 1080 // 默认缩放分辨率的短边长度
        },
        {
            "name": "桌面端",
            "type": "Win32",
            "win32": {
                "class_regex": ".*",
                "window_regex": "Visual Studio",
                // 截图及控制方式，请根据项目实际情况修改
                // 文档: https://maafw.xyz/docs/2.4-ControlMethods
                "screencap": "PrintWindow", // 截图方式
                "mouse": "PostMessageWithCursorPos", // 鼠标控制方式
                "keyboard": "PostMessageWithCursorPos" // 键盘控制方式
            }
        }
    ],
    "resource": [
        {
            "name": "官服",
            "path": [
                "./resource"
            ]
        }
    ],
    // 可选的 agent 示例
    // "agent": {
    //     "child_exec": "python",
    //     "child_args": [
    //         "./agent/main.py"
    //     ]
    // },
    "import": [
        "./resource/option/next_wave.json",
        "./resource/option/replanting_plants.json",
        "./resource/option/global_flower.json",
        "./resource/option/normal_accelerate.json",
        "./resource/option/normal_energy.json",
        "./resource/tasks/double.json",
        "./resource/tasks/dg1.json",
        "./resource/tasks/dg2.json",
        "./resource/tasks/heart_tower.json",
        "./resource/tasks/tower_banana.json",
        "./resource/tasks/yd_wj.json",
        "./resource/tasks/dai.json",
        "./resource/tasks/gold.json",
        "./resource/tasks/frame_wj.json",
        "./resource/tasks/active_tesk.json"
    ]
}