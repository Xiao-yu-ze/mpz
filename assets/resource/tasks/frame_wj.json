                                "frame_wj_boss_喂豆3-3"
                            ]
                        },
                        "frame_wj_boss_喂豆2-3": {
                            "next": [
                                "frame_wj_boss_过渡_相机神器2",
                                "frame_wj_boss_喂豆2-3"
