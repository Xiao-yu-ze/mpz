{
    "task": [
        {
            "name": "无尽挂机脚本框架",
            "entry": "Frame_Wj_Entry",
            "description": "脚本只负责点开始游戏,继续挑战,加速,补给等操作,可以摆自己设计的挂机阵,脚本默认开启划飞弹和点波,布好阵了在开脚本,不然种不了植物(详细的功能介绍见公告:设置->关于我们->显示公告)",
            "option": [
                "fw_初始化卡槽和草坪位置",
                "小关是否喂豆",
                "全局是否抛花",
                "fw_boss关是否需要喂豆",
                "是否需要补植物",
                "是否需要点波",
                "小关是否加速",
                "fw_boss关是否加速",
                "fw_boss_补给智能选取",
                //"fw_boss_是否开相机神器",
                "是否魔甘收尾(牢玩家专属)"
            ]
        }
    ],
    "option": {
        "fw_初始化卡槽和草坪位置": {
            "type": "switch",
            "label": "初始化卡槽和草坪位置",
            "description": "一定要开哦",
            "cases": [
                {
                    "name": "No",
                    "label": "否",
                    "pipeline_override": {
                        "Frame_Wj_Entry": {
                            "next": [
                                "plant_初始化"
                            ]
                        },
                        "plant_初始化完毕": {
                            "next": [
                                "frame_wj_过渡"
                            ]
                        }
                    }
                },
                {
                    "name": "Yes",
                    "label": "是",
                    "pipeline_override": {
                        "Frame_Wj_Entry": {
                            "next": [
                                "plant_初始化"
                            ]
                        },
                        "plant_初始化完毕": {
                            "next": [
                                "frame_wj_过渡"
                            ]
                        }
                    }
                }
            ]
        },
        "是否魔甘收尾(牢玩家专属)": {
            "type": "switch",
            "label": "是否魔甘收尾(牢玩家专属)",
            "cases": [
                {
                    "name": "No",
                    "label": "否",
                    "pipeline_override": {}
                },
                {
                    "name": "Yes",
                    "label": "是",
                    "pipeline_override": {
                        "frame_wj_划飞弹": {
                            "next": [
                                "判断是否魔甘收尾"
                            ]
                        }
                    }
                }
            ]
        },
        "fw_boss_是否开相机神器": {
            "type": "switch",
            "label": "boss关是否开相机神器复原植物",
            "description": "开启此功能默认关闭boss关加速",
            "cases": [
                {
                    "name": "No",
                    "label": "否",
                    "pipeline_override": {
                        "frame_wj_boss_过渡_相机神器1": {
                            "next": [
                                "frame_wj_boss_过渡"
                            ]
                        },
                        "frame_wj_boss_判断是否开启相机神器": {
                            "next": [
                                "frame_wj_boss_识别结算"
                            ]
                        }
                    }
                },
                {
                    "name": "Yes",
                    "label": "是",
                    "pipeline_override": {
                        "frame_wj_boss_判断是否进入关内": {
                            "action": "DoNothing"
                        },
                        "frame_wj_boss_喂豆5-3": {
                            "next": [
                                "frame_wj_boss_过渡_相机神器2",
                                "frame_wj_boss_喂豆5-3"
                            ]
                        },
                        "frame_wj_boss_喂豆4-3": {
